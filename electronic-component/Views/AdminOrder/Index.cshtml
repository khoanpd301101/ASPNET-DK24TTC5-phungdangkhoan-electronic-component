@model IEnumerable<electronic_component.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<section style="margin-top:30px; margin-bottom:40px;">
    <div class="container">
        <h2 class="title text-center">Quản lý đơn hàng</h2>

        <div class="table-responsive" style="background:#fff; padding:20px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08);">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>@item.Customer?.FullName</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @(item.Status == "Pending" ? "Chờ xử lý" :
                                                            item.Status == "Confirmed" ? "Đã xác nhận" :
                                                            item.Status == "Shipping" ? "Đang giao" :
                                                            item.Status == "Completed" ? "Hoàn thành" :
                                                            item.Status == "Cancelled" ? "Đã hủy" : item.Status)
                        </td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-default">Xem</a>
                        </td>
                    </tr>
                                        }
                </tbody>
            </table>
        </div>
    </div>
</section>