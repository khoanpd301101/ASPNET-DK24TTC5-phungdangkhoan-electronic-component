@model electronic_component.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<section style="margin-top: 30px; margin-bottom: 50px; background: #f8f9fb; padding: 30px 0;">
    <div class="container">
        <div class="row">
            <div class="col-sm-12 padding-right">
                <div style="margin-bottom: 25px;">
                    <h2 class="title text-center" style="margin-bottom: 10px;">Chi tiết đơn hàng #@Model.Id</h2>
                    <p class="text-center" style="color: #777; font-size: 16px;">
                        Theo dõi thông tin đơn hàng và danh sách sản phẩm đã đặt
                    </p>
                </div>

                <div class="row" style="margin-bottom: 30px;">
                    <div class="col-sm-7">
                        <div style="background: #fff; padding: 28px; border-radius: 16px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); min-height: 260px;">
                            <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 24px; font-weight: 700; color: #222;">
                                Thông tin đơn hàng
                            </h3>

                            <div style="margin-bottom: 12px;">
                                <span style="font-weight: 700; color: #333;">Ngày đặt:</span>
                                <span style="color: #666;"> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>

                            <div style="margin-bottom: 12px;">
                                <span style="font-weight: 700; color: #333;">Trạng thái:</span>
                                <span style="color: #FE980F; font-weight: 700;">
                                    @(Model.Status == "Pending" ? "Chờ xử lý" :
                                                                        Model.Status == "Confirmed" ? "Đã xác nhận" :
                                                                        Model.Status == "Shipping" ? "Đang giao" :
                                                                        Model.Status == "Completed" ? "Hoàn thành" :
                                                                        Model.Status == "Cancelled" ? "Đã hủy" : Model.Status)
                                </span>
                            </div>

                            <div style="margin-bottom: 12px;">
                                <span style="font-weight: 700; color: #333;">Địa chỉ giao hàng:</span>
                                <span style="color: #666;"> @Model.ShippingAddress</span>
                            </div>

                            <div style="margin-bottom: 12px;">
                                <span style="font-weight: 700; color: #333;">Số điện thoại:</span>
                                <span style="color: #666;"> @Model.PhoneNumber</span>
                            </div>

                            <div style="margin-bottom: 12px;">
                                <span style="font-weight: 700; color: #333;">Ghi chú:</span>
                                <span style="color: #666;">
                                    @(string.IsNullOrWhiteSpace(Model.Note) ? "Không có ghi chú" : Model.Note)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-5">
                        <div style="background: linear-gradient(135deg, #fff8ef, #fff1dc); padding: 28px; border-radius: 16px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); min-height: 260px;" class="text-center">
                            <div style="width: 80px; height: 80px; line-height: 80px; margin: 0 auto 20px auto; border-radius: 50%; background: #FE980F; color: #fff; font-size: 32px;">
                                <i class="fa fa-credit-card"></i>
                            </div>

                            <h3 style="margin-top: 0; font-size: 24px; font-weight: 700; color: #222;">
                                Tổng thanh toán
                            </h3>

                            <h2 style="color: #FE980F; font-weight: 800; margin-top: 25px; font-size: 36px;">
                                @Model.TotalAmount.ToString("N0") đ
                            </h2>

                            <p style="color: #666; margin-top: 10px;">
                                Tổng số sản phẩm: @Model.OrderDetails!.Sum(x => x.Quantity)
                            </p>

                            <div style="margin-top: 25px;">
                                <a asp-controller="Order" asp-action="Index" class="btn btn-default add-to-cart" style="border-radius: 25px; padding: 10px 20px;">
                                    Quay lại đơn hàng
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="background: #fff; padding: 25px; border-radius: 16px; box-shadow: 0 6px 20px rgba(0,0,0,0.08);">
                    <div style="margin-bottom: 20px;">
                        <h3 style="margin: 0; font-size: 24px; font-weight: 700; color: #222;">
                            Sản phẩm trong đơn hàng
                        </h3>
                    </div>

                    <div class="table-responsive">
                        <table class="table" style="margin-bottom: 0;">
                            <thead>
                                <tr style="background: #f8f9fb;">
                                    <th style="padding: 15px;">Hình ảnh</th>
                                    <th style="padding: 15px;">Sản phẩm</th>
                                    <th style="padding: 15px;">Số lượng</th>
                                    <th style="padding: 15px;">Đơn giá</th>
                                    <th style="padding: 15px;">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails!)
                                {
                                    <tr style="border-bottom: 1px solid #f1f1f1;">
                                        <td style="width: 110px; padding: 15px;">
                                            <div style="width: 80px; height: 80px; background: #f8f8f8; border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                                <img src="~/images/home/@item.Product?.ImageUrl"
                                                     alt="@item.Product?.Name"
                                                     class="img-responsive"
                                                     style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                                            </div>
                                        </td>

                                        <td style="vertical-align: middle; padding: 15px;">
                                            <h4 style="margin: 0; font-size: 18px; font-weight: 700; color: #222;">
                                                @item.Product?.Name
                                            </h4>
                                        </td>

                                        <td style="vertical-align: middle; padding: 15px; color: #555; font-weight: 600;">
                                            @item.Quantity
                                        </td>

                                        <td style="vertical-align: middle; padding: 15px; color: #555; font-weight: 600;">
                                            @item.UnitPrice.ToString("N0") đ
                                        </td>

                                        <td style="vertical-align: middle; padding: 15px; color: #FE980F; font-weight: 800; font-size: 18px;">
                                            @((item.UnitPrice * item.Quantity).ToString("N0")) đ
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>