@model electronic_component.Models.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section style="margin-top: 30px; margin-bottom: 30px;">
    <div class="container">
        <div class="row">
            <div class="col-sm-5 col-sm-offset-4">
                <div class="signup-form">
                    <h2>Đăng ký tài khoản</h2>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Register" asp-controller="Account" method="post">
                        <input asp-for="FullName" class="form-control" placeholder="Họ và tên" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                        <br />

                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <br />

                        <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <br />

                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        <br />

                        <input asp-for="Phone" class="form-control" placeholder="Số điện thoại" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                        <br />

                        <input asp-for="Address" class="form-control" placeholder="Địa chỉ" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                        <br />

                        <button type="submit" class="btn btn-default">Đăng ký</button>
                    </form>

                    <br />
                    <p>
                        Đã có tài khoản?
                        <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}