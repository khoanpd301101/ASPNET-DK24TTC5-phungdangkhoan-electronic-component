@model electronic_component.Models.Product

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa sản phẩm";
}

<section style="margin-top:30px; margin-bottom:40px;">
    <div class="container">
        <div class="row">
            <div class="col-sm-8 col-sm-offset-2">
                <div style="background:#fff; padding:30px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08);">

                    <p>Bạn có chắc muốn xóa sản phẩm này không?</p>

                    <p><strong>Tên:</strong> @Model.Name</p>
                    <p><strong>Giá:</strong> @Model.Price.ToString("N0") đ</p>
                    <p><strong>Danh mục:</strong> @Model.Category?.Name</p>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">Xóa</button>
                        <a asp-action="Index" class="btn btn-default">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>