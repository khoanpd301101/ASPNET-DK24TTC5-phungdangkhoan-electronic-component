@model electronic_component.Models.Product

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm sản phẩm";
}

<section style="margin-top:30px; margin-bottom:40px;">
    <div class="container">
        <div class="row">
            <div class="col-sm-8 col-sm-offset-2">
                <div style="background:#fff; padding:30px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08);">

                    <form asp-action="Create" method="post">
                        <div class="form-group">
                            <label>Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label>Mô tả</label>
                            <textarea asp-for="Description" class="form-control"></textarea>
                        </div>

                        <div class="form-group">
                            <label>Giá</label>
                            <input asp-for="Price" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label>Số lượng tồn</label>
                            <input asp-for="StockQuantity" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label>Hình ảnh</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label>Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-control"></select>
                        </div>

                        <button type="submit" class="btn btn-success">Lưu</button>
                        <a asp-action="Index" class="btn btn-default">Quay lại</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>