@model electronic_component.Models.Category

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa danh mục";
}

<div class="row">
    <div class="col-sm-8">
        <div style="background:#fff; padding:30px; border-radius:12px; box-shadow:0 4px 16px rgba(0,0,0,0.08);">

            <p>Bạn có chắc muốn xóa danh mục này không?</p>

            <p><strong>Tên danh mục:</strong> @Model.Name</p>
            <p><strong>Mô tả:</strong> @Model.Description</p>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a asp-action="Index" class="btn btn-default">Hủy</a>
            </form>
        </div>
    </div>
</div>