@model electronic_component.Models.Order

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<section style="margin-top:30px; margin-bottom:40px;">
    <div class="container">
        <h2 class="title text-center">Chi tiết đơn hàng #@Model.Id</h2>

        <div class="row" style="margin-bottom:25px;">
            <div class="col-sm-6">
                <div style="background:#fff; padding:25px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08); min-height:240px;">
                    <p><strong>Khách hàng:</strong> @Model.Customer?.FullName</p>
                    <p><strong>Email:</strong> @Model.Customer?.Email</p>
                    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                    <p><strong>SĐT:</strong> @Model.PhoneNumber</p>
                    <p><strong>Ghi chú:</strong> @Model.Note</p>
                </div>
            </div>

            <div class="col-sm-6">
                <div style="background:#fff; padding:25px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08); min-height:240px;">
                    <h3 style="margin-top:0;">Cập nhật trạng thái</h3>

                    <p>
                        <strong>Trạng thái hiện tại:</strong>
                        @(Model.Status == "Pending" ? "Chờ xử lý" :
                                                Model.Status == "Confirmed" ? "Đã xác nhận" :
                                                Model.Status == "Shipping" ? "Đang giao" :
                                                Model.Status == "Completed" ? "Hoàn thành" :
                                                Model.Status == "Cancelled" ? "Đã hủy" : Model.Status)
                    </p>

                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="form-group">
                            <label>Chọn trạng thái mới</label>
                            <select name="status" class="form-control">
                                <option value="Pending">Chờ xử lý</option>
                                <option value="Confirmed">Đã xác nhận</option>
                                <option value="Shipping">Đang giao</option>
                                <option value="Completed">Hoàn thành</option>
                                <option value="Cancelled">Đã hủy</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-warning">Cập nhật trạng thái</button>
                        <a asp-action="Index" class="btn btn-default">Quay lại</a>
                    </form>

                    <div style="margin-top:20px;">
                        <h3>Tổng tiền: <span style="color:#FE980F;">@Model.TotalAmount.ToString("N0") đ</span></h3>
                    </div>
                </div>
            </div>
        </div>

        <div style="background:#fff; padding:25px; border-radius:16px; box-shadow:0 6px 20px rgba(0,0,0,0.08);">
            <h3>Sản phẩm trong đơn</h3>

            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails!)
                        {
                            <tr>
                                <td style="width:100px;">
                                    <img src="~/images/home/@item.Product?.ImageUrl"
                                         alt="@item.Product?.Name"
                                         class="img-responsive"
                                         style="height:70px; width:100%; object-fit:contain;" />
                                </td>
                                <td>@item.Product?.Name</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("N0") đ</td>
                                <td>@((item.UnitPrice * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>